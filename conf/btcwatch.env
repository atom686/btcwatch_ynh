# Generated by the YunoHost installer. Edit and `systemctl restart __APP__` to
# pick up changes. Keep mode 0600 — this file holds the bot token.

# --- Telegram credentials (optional; balance changes are logged if blank) ---
TELEGRAM_BOT_TOKEN=__TELEGRAM_BOT_TOKEN__
TELEGRAM_CHAT_ID=__TELEGRAM_CHAT_ID__

# --- Polling ---
POLL_INTERVAL_SECONDS=__POLL_INTERVAL_SECONDS__

# --- App ---
PORT=__PORT__
RACK_ENV=production

# Persist watched addresses + last-known balances outside of the install dir
# so they survive `yunohost app upgrade`.
ADDRESSES_PATH=__DATA_DIR__/addresses.json

# Bundler — install gems under the install dir so the `btcwatch` system user
# can read them without root.
BUNDLE_PATH=__INSTALL_DIR__/vendor/bundle
BUNDLE_GEMFILE=__INSTALL_DIR__/Gemfile
GEM_HOME=__INSTALL_DIR__/vendor/bundle
