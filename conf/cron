# /etc/cron.d/__APP__ — runs the mempool.space poller every 5 minutes.
# Edit the schedule below if you want a different interval and run
# `systemctl reload cron` (or `service cron reload`) afterwards.
SHELL=/bin/bash
PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

*/5 * * * * __APP__ /usr/bin/php8.2 __INSTALL_DIR__/poll.php >> /var/log/__APP__/poll.log 2>&1
