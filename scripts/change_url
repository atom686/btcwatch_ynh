#!/bin/bash
# btcwatch change_url — updates the nginx site when domain or path changes.
# No stop/start needed: PHP-FPM and the cron job don't depend on the URL.

source /usr/share/yunohost/helpers

ynh_script_progression --message="Rewriting nginx config..."
ynh_config_change_url_nginx

ynh_script_progression --message="Change URL completed"
