#!/bin/bash
# btcwatch change_url — updates nginx + .env when domain or path changes.

source _common.sh
source /usr/share/yunohost/helpers

ynh_script_progression --message="Stopping btcwatch..."
ynh_systemctl --service="$app" --action="stop"

#=================================================
# REWRITE NGINX
#=================================================
ynh_script_progression --message="Rewriting nginx config..."
ynh_config_change_url_nginx

#=================================================
# REWRITE .env (in case anything in it depends on path/domain — none today,
# but cheap insurance for the future).
#=================================================
ynh_config_add --template="btcwatch.env" --destination="$install_dir/.env"
chown "$app:$app" "$install_dir/.env"
chmod 600 "$install_dir/.env"

ynh_script_progression --message="Starting btcwatch..."
ynh_systemctl --service="$app" --action="start"

ynh_script_progression --message="Change URL completed"
