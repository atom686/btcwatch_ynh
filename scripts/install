#!/bin/bash
# btcwatch install script — YunoHost packaging v2 (PHP edition).

source _common.sh
source /usr/share/yunohost/helpers

# Manifest install-question variables exposed by YunoHost:
#   $domain $path $app
#   $install_dir $data_dir
#   $telegram_bot_token $telegram_chat_id

#=================================================
# DEPLOY APPLICATION SOURCE
#=================================================
ynh_script_progression --message="Deploying btcwatch source..."

btcwatch_sync_source "$install_dir"

mkdir -p "$data_dir" "/var/log/$app"
[ -f "$data_dir/addresses.json" ] || echo "[]" > "$data_dir/addresses.json"

chown -R "$app:$app" "$install_dir" "$data_dir" "/var/log/$app"
chmod 750 "$data_dir" "/var/log/$app"
chmod 640 "$data_dir/addresses.json"

#=================================================
# WRITE config.php (paths only — secrets live in settings.json)
#=================================================
ynh_script_progression --message="Writing config.php..."
ynh_config_add --template="config.php" --destination="$install_dir/config.php"
chown "$app:$app" "$install_dir/config.php"
chmod 640 "$install_dir/config.php"

#=================================================
# SEED settings.json with install-time Telegram credentials (if any)
#=================================================
ynh_script_progression --message="Seeding runtime settings..."
btcwatch_seed_settings "$data_dir" "$app" "$telegram_bot_token" "$telegram_chat_id"

#=================================================
# PHP-FPM POOL + NGINX + CRON + LOGROTATE
#=================================================
ynh_script_progression --message="Adding PHP-FPM pool..."
ynh_config_add_phpfpm

ynh_script_progression --message="Adding nginx site..."
ynh_config_add_nginx

ynh_script_progression --message="Adding cron poller (runs every 5 minutes)..."
ynh_config_add --template="cron" --destination="/etc/cron.d/$app"
chown root:root "/etc/cron.d/$app"
chmod 644 "/etc/cron.d/$app"

ynh_script_progression --message="Adding logrotate config..."
ynh_config_add_logrotate "/var/log/$app"

ynh_script_progression --message="Installation completed"
