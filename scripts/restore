#!/bin/bash
# btcwatch restore script — counterpart to backup.

source _common.sh
source /usr/share/yunohost/helpers

ynh_script_progression --message="Restoring btcwatch..."

#--- Restore install + data dirs ---
ynh_restore_file --origin_path="$install_dir"
ynh_restore_file --origin_path="$data_dir"

chown -R "$app:$app" "$install_dir" "$data_dir"
chmod 600 "$install_dir/.env" 2>/dev/null || true

#--- Restore systemd + nginx ---
ynh_restore_file --origin_path="/etc/systemd/system/$app.service"
systemctl daemon-reload

ynh_restore_file --origin_path="/etc/nginx/conf.d/$domain.d/$app.conf"

yunohost service add "$app" \
    --description="Bitcoin Address Watch — mempool.space monitor + Telegram notifier"

ynh_script_progression --message="Reloading nginx..."
ynh_systemctl --service="nginx" --action="reload"

ynh_script_progression --message="Starting btcwatch..."
ynh_systemctl --service="$app" --action="start" || true

ynh_script_progression --message="Restore completed"
