#!/bin/bash
# btcwatch restore script — counterpart to backup.

source _common.sh
source /usr/share/yunohost/helpers

ynh_script_progression --message="Restoring btcwatch..."

#--- install + data dirs ---
ynh_restore_file --origin_path="$install_dir"
ynh_restore_file --origin_path="$data_dir"

chown -R "$app:$app" "$install_dir" "$data_dir"
chmod 600 "$data_dir/settings.json" 2>/dev/null || true

mkdir -p "/var/log/$app"
chown "$app:$app" "/var/log/$app"
chmod 750 "/var/log/$app"

#--- PHP-FPM pool ---
ynh_restore_file --origin_path="/etc/php/${YNH_PHP_VERSION:-8.2}/fpm/pool.d/$app.conf"
ynh_systemctl --service="php${YNH_PHP_VERSION:-8.2}-fpm" --action="reload"

#--- Nginx ---
ynh_restore_file --origin_path="/etc/nginx/conf.d/$domain.d/$app.conf"
ynh_systemctl --service="nginx" --action="reload"

#--- Cron + logrotate ---
ynh_restore_file --origin_path="/etc/cron.d/$app"
ynh_restore_file --origin_path="/etc/logrotate.d/$app"

ynh_script_progression --message="Restore completed"
