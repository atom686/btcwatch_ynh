#!/bin/bash
# btcwatch restore — counterpart to backup. v2 helpers: ynh_restore (positional).

source /usr/share/yunohost/helpers

ynh_script_progression --message="Restoring btcwatch..."

# install + data dirs
ynh_restore "$install_dir"
ynh_restore "$data_dir"

chown -R "$app:$app" "$install_dir" "$data_dir"
chmod 600 "$data_dir/settings.json" 2>/dev/null || true

mkdir -p "/var/log/$app"
chown "$app:$app" "/var/log/$app"
chmod 750 "/var/log/$app"

# PHP-FPM pool
ynh_restore "/etc/php/${YNH_PHP_VERSION:-8.3}/fpm/pool.d/$app.conf"
ynh_systemctl --service="php${YNH_PHP_VERSION:-8.3}-fpm" --action="reload"

# Nginx
ynh_restore "/etc/nginx/conf.d/$domain.d/$app.conf"
ynh_systemctl --service="nginx" --action="reload"

# Cron + logrotate
ynh_restore "/etc/cron.d/$app"
ynh_restore "/etc/logrotate.d/$app"

ynh_script_progression --message="Restore completed"
