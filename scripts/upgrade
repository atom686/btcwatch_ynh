#!/bin/bash
# btcwatch upgrade script.

source _common.sh
source /usr/share/yunohost/helpers

#=================================================
# REPLACE SOURCE
#=================================================
ynh_script_progression --message="Refreshing source code..."

btcwatch_sync_source "$install_dir"
chown -R "$app:$app" "$install_dir"

mkdir -p "$data_dir" "/var/log/$app"
chown -R "$app:$app" "$data_dir" "/var/log/$app"
[ -f "$data_dir/addresses.json" ] || {
    echo "[]" > "$data_dir/addresses.json"
    chown "$app:$app" "$data_dir/addresses.json"
    chmod 640 "$data_dir/addresses.json"
}

#=================================================
# REWRITE config.php (paths only)
#=================================================
ynh_script_progression --message="Updating config.php..."
ynh_config_add --template="config.php" --destination="$install_dir/config.php"
chown "$app:$app" "$install_dir/config.php"
chmod 640 "$install_dir/config.php"

# settings.json is preserved as-is; we never overwrite values the user has
# saved via the web UI. The seed helper only fills empty fields.
btcwatch_seed_settings "$data_dir" "$app" "$telegram_bot_token" "$telegram_chat_id"

#=================================================
# REFRESH PHP-FPM, NGINX, CRON, LOGROTATE
#=================================================
ynh_script_progression --message="Refreshing PHP-FPM pool..."
ynh_config_add_phpfpm

ynh_script_progression --message="Refreshing nginx..."
ynh_config_add_nginx

ynh_script_progression --message="Refreshing cron..."
ynh_config_add --template="cron" --destination="/etc/cron.d/$app"
chown root:root "/etc/cron.d/$app"
chmod 644 "/etc/cron.d/$app"

ynh_script_progression --message="Refreshing logrotate..."
ynh_config_add_logrotate "/var/log/$app"

ynh_script_progression --message="Upgrade completed"
